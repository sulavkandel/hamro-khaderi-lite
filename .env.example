# ---------- Django backend ----------
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (default) — set USE_SQLITE=1 to fall back to SQLite
USE_SQLITE=0
POSTGRES_DB=khaderi
POSTGRES_USER=khaderi
POSTGRES_PASSWORD=khaderi
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Weather provider: open_meteo | dhm (stub)
WEATHER_SOURCE=open_meteo
HISTORY_START_DATE=2012-01-01
ARCHIVE_LAG_DAYS=5
PRECIP_MAX_MM_PER_DAY=500

# Start the weekly APScheduler job inside the web process
SCHEDULER_AUTOSTART=1

# ---------- Next.js frontend ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
